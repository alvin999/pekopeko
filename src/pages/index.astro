---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";
import AvatarGenerator from "../components/AvatarGenerator.svelte";
import BowButton from "../components/BowButton.svelte";
import { getLocalDateString } from "../lib/dateUtils";

const cookieDate = Astro.cookies.get("user_today")?.value;
const serverToday = getLocalDateString();

// 優先使用 Cookie 中的日期，若無則回退至伺服器日期
const today = cookieDate || serverToday;

// 僅查詢今日貼文，按 hot (bow_count) 排序
const { data: posts, error } = await supabase
  .from("posts")
  .select(
    `
    *,
    profiles (username),
    shops (name),
    item_name,
    location_name
  `,
  )
  .eq("post_date", today)
  .order("bow_count", { ascending: false });
---

<Layout title="杯口杯口 PekoPeko | 今日熱門飲品">
  <div class="container mx-auto px-4 py-20">
    <div class="flex flex-col items-center mb-20 text-center">
      <h1
        class="text-6xl md:text-8xl font-black uppercase tracking-tighter italic title-outline mb-6"
      >
        今日熱門
      </h1>
      <p
        class="text-lg font-bold opacity-70 max-w-lg border-[--color-border] pb-2"
      >
        今日限定，每日 0 點準時重設。
      </p>
      <p
        class="text-lg font-bold opacity-70 max-w-lg border-b-2 border-[--color-border] pb-2"
      >
        一日一次的感動足跡。
      </p>
    </div>

    {
      error && (
        <div class="alert brutalist-card bg-error text-error-content max-w-md mx-auto mb-8">
          {error.message}
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {
        posts?.map((post) => (
          <div class="brutalist-card flex flex-col group">
            <div class="p-6 flex flex-col gap-4 border-b-4 border-[--color-border] bg-white relative overflow-hidden">
              <div class="absolute right-6 top-6 text-3xl opacity-30 grayscale group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500 rotate-12 z-10">
                {post.drink_type === 'coffee' ? '☕' : '🍵'}
              </div>
              <div class="flex flex-col relative z-20">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-4xl leading-none">
                    {post.mood}
                  </span>
                  <span class="font-black italic uppercase text-3xl tracking-tighter title-outline-sm leading-none pt-1">
                    {post.item_name || (post.drink_type === 'coffee' ? '咖啡' : '茶')}
                  </span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="text-[10px] font-bold opacity-60 bg-black/5 px-2 py-0.5 flex gap-1">
                    <span>POSTED AT:</span>
                    <span
                      data-time={post.created_at}
                      data-format="short"
                    >
                      {new Intl.DateTimeFormat("zh-TW", {
                        hour: "2-digit",
                        minute: "2-digit",
                        hour12: false,
                      }).format(new Date(post.created_at))}
                    </span>
                  </div>
                </div>
              </div>
            </div>

            <div class="p-8 flex flex-col items-center gap-8 bg-[#F5F2EA]">
              <a
                href={`/post/${post.id}`}
                class="hover:scale-105 transition-transform"
              >
                <AvatarGenerator
                  client:visible
                  drinkType={post.drink_type}
                  flavors={post.flavors}
                  mouthfeel={post.mouthfeel}
                  mood={post.mood}
                  size={240}
                />
              </a>

              <div class="flex flex-wrap justify-center gap-2">
                {post.flavors.map((f: string) => (
                  <span class="brutalist-badge badge-white">{f}</span>
                ))}
              </div>

              <div class="flex items-center justify-between w-full mt-4 border-t-2 border-[--color-border] pt-6">
                <div class="flex gap-4 items-center">
                  <div class="flex items-center gap-2">
                    <span class="text-2xl">
                      📍
                    </span>
                    {(post.shops?.name || (post.shops as any)?.[0]?.name || post.location_name) && (
                      <span class="text-[10px] font-black uppercase">
                        {post.shops?.name || (post.shops as any)?.[0]?.name || post.location_name}
                      </span>
                    )}
                  </div>
                </div>
                <BowButton
                  client:load
                  postId={post.id}
                  initialCount={post.bow_count}
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    {
      (!posts || posts.length === 0) && (
        <div class="text-center py-20 brutalist-card bg-white max-w-2xl mx-auto">
          <p class="text-3xl font-black uppercase italic">目前還沒有貼文</p>
          <p class="mt-2 font-bold opacity-60">成為今天第一個分享的人吧！</p>
          <a href="/create" class="brutalist-btn-primary mt-8">
            立刻去發文 →
          </a>
        </div>
      )
    }

    <script is:inline define:vars={{ serverToday: today }}>
      (function() {
        const now = new Date();
        const clientDate = now.getFullYear() + '-' + 
                           String(now.getMonth() + 1).padStart(2, '0') + '-' + 
                           String(now.getDate()).padStart(2, '0');
        
        if (serverToday !== clientDate) {
          document.cookie = "user_today=" + clientDate + "; path=/; max-age=86400; SameSite=Lax";
          window.location.reload();
        }
      })();
    </script>
  </div>
</Layout>
