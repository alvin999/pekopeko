---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import AvatarGenerator from '../../components/AvatarGenerator.svelte';
import BowButton from '../../components/BowButton.svelte';
import ShareActions from '../../components/ShareActions.svelte';
import MapView from '../../components/map/MapView.svelte';

const { id } = Astro.params;

const { data: post, error } = await supabase
  .from('posts')
  .select(`
    *,
    profiles (username),
    shops (name, latitude, longitude)
  `)
  .eq('id', id)
  .single();

if (!post) {
  return Astro.redirect('/404');
}

const drinkName = post.item_name || (post.drink_type === 'coffee' ? '咖啡' : '茶');
const drinkTitle = `今日的${drinkName}`;

const userLang = Astro.request.headers.get('accept-language')?.split(',')[0] || 'zh-TW';
---

<Layout title={`${drinkTitle} | 杯口杯口`}>
  <div class="container mx-auto px-4 py-20 max-w-5xl">
    <div class="brutalist-card bg-white p-8 md:p-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div id="avatar-target" class="flex justify-center p-12 bg-[#F5F2EA] border-6 border-[--color-border] shadow-[12px_12px_0px_0px_var(--color-border)]">
          <AvatarGenerator 
            client:load
            drinkType={post.drink_type} 
            flavors={post.flavors} 
            mouthfeel={post.mouthfeel} 
            mood={post.mood} 
            size={400} 
          />
        </div>

        <div class="space-y-12">
          <div>
            <div class="brutalist-badge badge-coffee text-sm! px-4! mb-4">SPECIFICATIONS</div>
            <h1 class="text-5xl font-black italic title-outline mb-4">{drinkTitle}</h1>
            <p class="font-bold opacity-60 uppercase tracking-widest text-xs border-b-2 border-[--color-border] pb-4">
              TIMESTAMP: <time-formatter data-time={post.created_at} data-format="full">
                {new Intl.DateTimeFormat(userLang, {
                  year: 'numeric',
                  month: '2-digit',
                  day: '2-digit',
                  hour: '2-digit',
                  minute: '2-digit',
                  hour12: false
                }).format(new Date(post.created_at))}
              </time-formatter>
            </p>
          </div>

          <div class="space-y-4">
            <p class="font-black text-xs uppercase tracking-tighter opacity-40">Flavor Profile</p>
            <div class="flex flex-wrap gap-3">
              {post.flavors.map((f: string) => (
                <span class="brutalist-badge badge-white text-sm! px-4!">{f}</span>
              ))}
              <span class="brutalist-badge badge-tea text-white! text-sm! px-4! uppercase">MOUTHFEEL: {post.mouthfeel}</span>
            </div>
          </div>

          <div class="brutalist-card bg-[--color-accent] p-8 flex items-center justify-between shadow-[--brutalist-shadow-sm]">
            <div class="text-7xl">{post.mood}</div>
            <div class="text-right">
              <div class="text-xs font-black uppercase tracking-[0.2em] mb-2 opacity-70">Accumulated Bows</div>
              <div class="text-5xl font-black">{post.bow_count}</div>
            </div>
          </div>

          {post.shops?.latitude && post.shops?.longitude && (
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <p class="font-black text-xs uppercase tracking-tighter opacity-40">Location</p>
                {!post.shops?.is_verified && (
                  <a href={`/claim?shop_id=${post.shop_id}`} class="text-[10px] bg-black text-white px-2 py-1 font-bold hover:bg-accent hover:text-black transition-colors">
                    CLAIM THIS SHOP
                  </a>
                )}
              </div>
              <MapView 
                client:load 
                lat={post.shops.latitude} 
                lng={post.shops.longitude} 
                name={post.shops.name || post.location_name} 
              />
            </div>
          )}

          <div class="pt-8 border-t-4 border-[--color-border] flex flex-col sm:flex-row gap-6">
            <BowButton client:load postId={post.id} initialCount={post.bow_count} />
            <div class="flex-1">
               <ShareActions client:load drinkName={drinkTitle} />
            </div>
          </div>
          
        </div>
      </div>
    </div>
  </div>
</Layout>
