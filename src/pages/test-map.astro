---
import Layout from '../layouts/Layout.astro';
import MapPicker from '../components/map/MapPicker.svelte';
import MapView from '../components/map/MapView.svelte';
---

<Layout title="地圖連線測試 | Test Map">
  <div class="max-w-4xl mx-auto p-4 space-y-12 py-12">
    <div class="text-center">
      <h1 class="text-4xl font-black italic title-outline mb-4">MAP DEBUG PAGE</h1>
      <p class="font-bold opacity-60 uppercase tracking-widest text-xs border-b-2 border-[--color-border] inline-block pb-2">
        測試 Production 環境下的地圖渲染狀況
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Test Area 1: MapPicker -->
      <section class="space-y-4">
        <h2 class="font-black text-xl uppercase italic">1. MapPicker (Interactive)</h2>
        <div class="brutalist-card bg-[#F5F2EA] p-4">
          <MapPicker 
            location={{ lat: 25.0339, lng: 121.5645 }} 
            onChange={(d) => console.log('Picker Change:', d)}
          />
        </div>
      </section>

      <!-- Test Area 2: MapView -->
      <section class="space-y-4">
        <h2 class="font-black text-xl uppercase italic">2. MapView (Static)</h2>
        <div class="brutalist-card bg-[#F5F2EA] p-4">
          <MapView 
            lat={25.0339}
            lng={121.5645}
            name="台北 101"
          />
        </div>
      </section>
    </div>

    <div class="brutalist-card bg-accent p-6 text-center">
        <p class="font-black uppercase italic">如果看到地圖，代表 setTimeout + resize 修復成功！</p>
    </div>
  </div>
</Layout>
